OPENCLAW_URL=http://localhost:18789/v1/chat/completions
OPENCLAW_TOKEN=replace-me
OPENCLAW_MODEL=openclaw

# HermesClock: Hermes Agent API Server OpenAI-compatible.
# Habilitar en ~/.hermes/.env:
# API_SERVER_ENABLED=true
# API_SERVER_HOST=127.0.0.1
# API_SERVER_PORT=8642
# API_SERVER_MODEL_NAME=hermes-agent
# API_SERVER_KEY=replace-me
HERMES_API_URL=http://127.0.0.1:8642/v1/chat/completions
HERMES_API_TOKEN=replace-me
HERMES_MODEL=hermes-agent
HERMES_TIMEOUT=240

# Claude Clock: API nativa Anthropic Messages.
# Mantén esta key solo en el backend; nunca en la app watchOS.
CLAUDE_API_URL=https://api.anthropic.com/v1/messages
CLAUDE_API_KEY=replace-me
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_TIMEOUT=240
CLAUDE_MAX_TOKENS=500

# Notificaciones push (ntfy). Genera un topic impredecible (funciona como contraseña):
#   python3 -c "import secrets; print('openclock-' + secrets.token_hex(8))"
# Suscríbete al mismo topic en la app ntfy (iOS/Android). Vacío = push deshabilitado.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=
NTFY_TOKEN=
